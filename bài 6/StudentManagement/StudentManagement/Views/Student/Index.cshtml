@model List<StudentManagement.Models.Student>

@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<h2>Danh sách Sinh viên</h2>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">

    <a href="/Student/Create" style="padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px;">+ Thêm sinh viên mới</a>

    <form method="get" action="/Student/Index" style="margin: 0;">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" placeholder="Tìm tên hoặc email..." style="padding: 5px;" />
        <button type="submit" style="padding: 5px 10px;">Tìm kiếm</button>
        <a href="/Student/Index" style="margin-left: 5px;">Bỏ lọc</a>
    </form>

</div>

@if (Model.Count == 0)
{
    <p>Không tìm thấy dữ liệu sinh viên nào phù hợp.</p>
}
else
{
    <table border="1" cellpadding="10" cellspacing="0" style="width: 100%; text-align: left;">
        <tr style="background-color: #f2f2f2;">
            <th>Id</th>
            <th>Tên</th>
            <th>Email</th>
            <th>Số điện thoại</th>
            <th>Hành động</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td>
                    <a href="/Student/Detail/@item.Id">Chi tiết</a> |
                    <a href="/Student/Edit/@item.Id">Sửa</a> |
                    <a href="/Student/Delete/@item.Id" onclick="return confirm('Bạn có chắc muốn xóa sinh viên này?');">Xóa</a>
                </td>
            </tr>
        }
    </table>
}

@section Scripts {
    <script>
        console.log("Trang danh sách đã được tải");
    </script>
}